# ENVIRONMENT
NODE_ENV=development
PORT=3000

# DATABASE
MONGODB_URI=mongodb://localhost:27017/licitaciones-salud
# Para MongoDB Atlas:
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/licitaciones-salud?retryWrites=true&w=majority

# JWT
JWT_SECRET=tu_secreto_super_seguro_cambiar_en_produccion
JWT_EXPIRE=7d

# GEMINI API (para resolución de captchas)
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-2.5-flash

# REDIS (para Bull Queue) - Opcional
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SCRAPING CONFIG
SCRAPING_ENABLED=true
SCRAPING_CRON_SCHEDULE=0 */6 * * *
BASE_URL=https://www.compraspublicas.gob.ec/ProcesoContratacion/compras/PC/buscarProceso.cpe?sg=1#

# LOGGING
LOG_LEVEL=info
LOG_FILE=logs/app.log

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000
